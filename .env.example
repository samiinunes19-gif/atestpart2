# Chaves da MasterPag (PayGateway) — configure no painel da Vercel (Environment Variables)
# NÃO comite este arquivo com valores reais. Use .env apenas localmente.

# Use pk_test_ / sk_test_ enquanto testa; troque por pk_live_ / sk_live_ ao ir ao ar.
MASTERPAG_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
MASTERPAG_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx

# Secret do webhook (para validar a assinatura HMAC-SHA256). Opcional, mas recomendado.
MASTERPAG_WEBHOOK_SECRET=

# Opcional: sobrescrever a base URL da API (padrão já aponta para produção)
# MASTERPAG_BASE_URL=https://api.masterpag.com/functions/v1
